  <!-- ═══════════════════════════════════════════════════════════════════
       PAGE 3 — Scoring & Weighting Framework
       ═══════════════════════════════════════════════════════════════════ -->
  <diagram name="Scoring Framework" id="page-scoring">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1"
                  connect="1" arrows="1" fold="1" page="1" pageScale="1"
                  pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ── PAGE TITLE ── -->
        <mxCell id="p3_title" value="Finance LLM Benchmark — Scoring &amp; Weighting Framework"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;
                 verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;
                 fontColor=#1a1a2e;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="15" width="1200" height="50" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════
             SECTION A — Score Normalization
             ══════════════════════════════════ -->
        <mxCell id="norm_title" value="A.  Score Normalization Rules"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;
                 fontSize=14;fontStyle=1;fontColor=#003087;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="400" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="norm_box1" value="&lt;b&gt;Higher-is-Better Metrics&lt;/b&gt; (Accuracy, F1, ROUGE, Pass@k)&lt;br/&gt;&lt;br/&gt;Normalized Score = 100 × (raw − min_baseline) / (max_possible − min_baseline)&lt;br/&gt;&lt;br/&gt;• min_baseline = random baseline OR worst observed in cohort&lt;br/&gt;• max_possible = 1.0 (accuracy) OR human benchmark level"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;
                 fontSize=11;verticalAlign=top;align=left;spacingLeft=10;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="115" width="520" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="norm_box2" value="&lt;b&gt;Lower-is-Better Metrics&lt;/b&gt; (Hallucination Rate, Latency, ECE)&lt;br/&gt;&lt;br/&gt;Normalized Score = 100 × (1 − (raw − target_min) / (target_max − target_min))&lt;br/&gt;&lt;br/&gt;• target_min = best achievable value (e.g., 0ms latency, 0% HR)&lt;br/&gt;• target_max = worst acceptable threshold (e.g., 10s latency)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;
                 fontSize=11;verticalAlign=top;align=left;spacingLeft=10;"
          vertex="1" parent="1">
          <mxGeometry x="580" y="115" width="520" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="composite_box" value="&lt;b&gt;Composite Score Formula&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Composite(model, use_case) = Σ  [ Weight_i(use_case) × NormalizedScore_i(model) ]&lt;br/&gt;&lt;br/&gt;All normalized scores are in [0, 100].  Weights sum to 100% within each use case."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;
                 fontSize=11;verticalAlign=top;align=left;spacingLeft=10;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="255" width="1060" height="75" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════
             SECTION B — Dimension Weight Matrix
             ══════════════════════════════════ -->
        <mxCell id="wtmatrix_title" value="B.  Dimension Weight Matrix by Use Case  (values in %)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;
                 fontSize=14;fontStyle=1;fontColor=#003087;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="700" height="30" as="geometry"/>
        </mxCell>

