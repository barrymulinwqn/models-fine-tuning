             ══════════════════════════════════ -->
        <mxCell id="d6_box" value="&lt;b&gt;D6 — Latency &amp; Throughput&lt;/b&gt;&lt;br/&gt;&lt;hr/&gt;Default Weight: 5–10%&lt;br/&gt;&lt;br/&gt;Metrics:&lt;br/&gt;• TTFT — Time to First Token&lt;br/&gt;• P50 / P95 Completion Latency&lt;br/&gt;• Throughput TPS (≥ 500)&lt;br/&gt;• Peak VRAM Usage (GB)&lt;br/&gt;• Cost / 1M tokens (USD)&lt;br/&gt;&lt;br/&gt;Profiles: Latency-Critical,&lt;br/&gt;Interactive, Batch"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;
                 fontSize=10;verticalAlign=top;align=left;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="550" y="760" width="220" height="215" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════
             D7 — Context Window Handling  (BOTTOM-LEFT)
             ══════════════════════════════════ -->
        <mxCell id="d7_box" value="&lt;b&gt;D7 — Context Window Handling&lt;/b&gt;&lt;br/&gt;&lt;hr/&gt;Default Weight: 5–10%&lt;br/&gt;&lt;br/&gt;Metrics:&lt;br/&gt;• NIAH Accuracy (≥ 0.80)&lt;br/&gt;• Position Bias Score (≤ 0.10)&lt;br/&gt;• Multi-hop Recall F1 (≥ 0.65)&lt;br/&gt;• Long-Context Faithfulness&lt;br/&gt;&lt;br/&gt;Test Lengths:&lt;br/&gt;4K / 8K / 16K / 32K / 64K / 128K&lt;br/&gt;tokens"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0ff;strokeColor=#6666cc;
                 fontSize=10;verticalAlign=top;align=left;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="220" height="210" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════
             D8 — Code Generation  (MID-LEFT)
             ══════════════════════════════════ -->
        <mxCell id="d8_box" value="&lt;b&gt;D8 — Code Generation&lt;/b&gt;&lt;br/&gt;&lt;hr/&gt;Default Weight: 5–10%&lt;br/&gt;&lt;br/&gt;Metrics:&lt;br/&gt;• Pass@1 (≥ 0.55)&lt;br/&gt;• Pass@3 (≥ 0.75)&lt;br/&gt;• Compilation Rate (≥ 0.95)&lt;br/&gt;• Numerical Correctness&lt;br/&gt;• SQL Execution Accuracy&lt;br/&gt;&lt;br/&gt;Datasets:&lt;br/&gt;• FinCode-Eval (Python)&lt;br/&gt;• SQLFinBench"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;
                 fontSize=10;verticalAlign=top;align=left;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="375" width="220" height="215" as="geometry"/>
        </mxCell>

